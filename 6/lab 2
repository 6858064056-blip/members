<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thai Consonant Drill</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f2f4f8;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      color: #222;
    }

    .card {
      width: 90%;
      max-width: 420px;
      background: white;
      border-radius: 14px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
      padding: 28px 24px;
      text-align: center;
    }

    .hidden {
      display: none;
    }

    h1, h2, h3, p {
      margin: 0;
    }

    .subtitle {
      margin-top: 8px;
      color: #555;
      font-size: 15px;
    }

    .input-group {
      margin-top: 18px;
    }

    input {
      width: 100%;
      padding: 10px 12px;
      font-size: 15px;
      border: 1px solid #bbb;
      border-radius: 8px;
      outline: none;
    }

    input:focus {
      border-color: #4f7cff;
    }

    button {
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 15px;
      transition: 0.2s ease;
    }

    .primary-btn {
      margin-top: 14px;
      background: #4f7cff;
      color: white;
      padding: 10px 18px;
      min-width: 120px;
    }

    .primary-btn:hover {
      background: #3e68e8;
    }

    .answer-btn {
      display: block;
      width: 100%;
      margin: 12px 0;
      padding: 14px 16px;
      background: #e9ecef;
      color: #222;
      font-size: 17px;
      border-radius: 8px;
    }

    .answer-btn:hover {
      background: #dfe4ea;
    }

    .top-line {
      font-size: 22px;
      margin-bottom: 10px;
    }

    .hearts {
      font-size: 28px;
      margin: 8px 0 4px;
      color: #e25555;
    }

    .remaining {
      font-size: 18px;
      margin-bottom: 18px;
    }

    .title {
      font-size: 34px;
      margin: 30px 0 30px;
      font-weight: normal;
    }

    .quiz-heading {
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 24px;
    }

    .message {
      margin-top: 12px;
      min-height: 20px;
      color: #d22;
      font-size: 14px;
    }

    .success {
      color: green;
    }

    .gameover {
      margin-top: 20px;
      font-size: 24px;
      color: #d22;
      font-weight: bold;
    }

    .small-note {
      margin-top: 10px;
      color: #666;
      font-size: 13px;
    }
  </style>
</head>
<body>

  <!-- LOGIN SCREEN -->
  <div class="card" id="loginScreen">
    <h2>CSII Team X presents</h2>
    <p class="subtitle">Thai Consonants</p>

    <div class="input-group">
      <input type="text" id="username" placeholder="Enter your name" />
    </div>

    <button class="primary-btn" onclick="login()">Start Quiz</button>
    <div class="message" id="loginMessage"></div>
    <p class="small-note">Demo API login is included below. You can replace it with a real backend later.</p>
  </div>

  <!-- GAME SCREEN -->
  <div class="card hidden" id="gameScreen">
    <div class="top-line">
      <span id="playerName">Player</span> — Starts: <span id="score">0</span>
    </div>

    <div class="hearts" id="heartsDisplay">❤️❤️❤️</div>
    <div class="remaining">Remaining: <span id="remainingCount">18</span></div>

    <div class="quiz-heading">Thai Consonant Drill</div>

    <div class="title" id="letter">ก</div>

    <div id="choices"></div>

    <div class="gameover" id="gameoverMessage"></div>
    <button class="primary-btn hidden" id="restartBtn" onclick="restartGame()">Restart</button>
  </div>

  <script>
    const consonants = [
      { letter: "ก", answer: "gor gai — Middle" },
      { letter: "ข", answer: "kor kai — High" },
      { letter: "ค", answer: "kor kwai — Low" },
      { letter: "ง", answer: "ngor ngoo — Low" },
      { letter: "จ", answer: "jor jaan — Middle" },
      { letter: "ช", answer: "chor chang — Low" },
      { letter: "ด", answer: "dor chada — Middle" },
      { letter: "ต", answer: "dtor tao — Middle" },
      { letter: "บ", answer: "bor baimai — Middle" },
      { letter: "ป", answer: "por pla — Middle" },
      { letter: "ม", answer: "mor ma — Low" },
      { letter: "ย", answer: "yor yak — Low" },
      { letter: "ร", answer: "ror rua — Low" },
      { letter: "ล", answer: "lor ling — Low" },
      { letter: "ว", answer: "wor waen — Low" },
      { letter: "ส", answer: "sor suea — High" },
      { letter: "ห", answer: "hor hip — High" },
      { letter: "อ", answer: "or aang — Middle" }
    ];

    let currentQuestion = null;
    let score = 0;
    let hearts = 3;
    let remaining = consonants.length;
    let usedIndexes = [];
    let currentPlayer = "";

    // -----------------------------
    // DEMO API LOGIN FUNCTION
    // Replace this with a real API fetch later if needed
    // -----------------------------
    function fakeLoginAPI(username) {
      return new Promise((resolve, reject) => {
        setTimeout(() => {
          if (!username || username.trim() === "") {
            reject({ message: "Please enter your name." });
          } else {
            resolve({
              success: true,
              user: {
                name: username.trim()
              }
            });
          }
        }, 600);
      });
    }

    async function login() {
      const usernameInput = document.getElementById("username");
      const loginMessage = document.getElementById("loginMessage");
      const username = usernameInput.value.trim();

      loginMessage.textContent = "Logging in...";

      try {
        // Demo API call
        const response = await fakeLoginAPI(username);

        if (response.success) {
          currentPlayer = response.user.name;
          document.getElementById("playerName").textContent = currentPlayer;

          document.getElementById("loginScreen").classList.add("hidden");
          document.getElementById("gameScreen").classList.remove("hidden");

          loginMessage.textContent = "";
          restartGame();
        }
      } catch (error) {
        loginMessage.textContent = error.message || "Login failed.";
      }
    }

    function updateHeartsDisplay() {
      let heartsText = "";
      for (let i = 0; i < hearts; i++) {
        heartsText += "❤️";
      }
      document.getElementById("heartsDisplay").textContent = heartsText || "0";
    }

    function shuffleArray(array) {
      return array.sort(() => Math.random() - 0.5);
    }

    function getUnusedQuestionIndex() {
      if (usedIndexes.length === consonants.length) {
        return null;
      }

      let index;
      do {
        index = Math.floor(Math.random() * consonants.length);
      } while (usedIndexes.includes(index));

      usedIndexes.push(index);
      return index;
    }

    function newQuestion() {
      if (hearts <= 0) {
        endGame();
        return;
      }

      const questionIndex = getUnusedQuestionIndex();

      if (questionIndex === null) {
        document.getElementById("letter").textContent = "🎉";
        document.getElementById("choices").innerHTML = "";
        document.getElementById("gameoverMessage").textContent = "You completed all questions!";
        document.getElementById("restartBtn").classList.remove("hidden");
        return;
      }

      currentQuestion = consonants[questionIndex];
      document.getElementById("letter").textContent = currentQuestion.letter;

      let options = [currentQuestion.answer];

      while (options.length < 3) {
        const randomChoice = consonants[Math.floor(Math.random() * consonants.length)].answer;
        if (!options.includes(randomChoice)) {
          options.push(randomChoice);
        }
      }

      shuffleArray(options);

      const choicesDiv = document.getElementById("choices");
      choicesDiv.innerHTML = "";

      options.forEach(option => {
        const btn = document.createElement("button");
        btn.className = "answer-btn";
        btn.textContent = option;
        btn.onclick = () => checkAnswer(option);
        choicesDiv.appendChild(btn);
      });

      document.getElementById("remainingCount").textContent = consonants.length - usedIndexes.length + 1;
    }

    function checkAnswer(selected) {
      if (hearts <= 0) return;

      if (selected === currentQuestion.answer) {
        score++;
      } else {
        hearts--;
      }

      remaining = consonants.length - usedIndexes.length;

      document.getElementById("score").textContent = score;
      document.getElementById("remainingCount").textContent = remaining;
      updateHeartsDisplay();

      if (hearts <= 0) {
        endGame();
      } else {
        newQuestion();
      }
    }

    function endGame() {
      document.getElementById("choices").innerHTML = "";
      document.getElementById("gameoverMessage").textContent = "Game Over!";
      document.getElementById("restartBtn").classList.remove("hidden");
    }

    function restartGame() {
      score = 0;
      hearts = 3;
      remaining = consonants.length;
      usedIndexes = [];
      currentQuestion = null;

      document.getElementById("score").textContent = score;
      document.getElementById("remainingCount").textContent = remaining;
      document.getElementById("gameoverMessage").textContent = "";
      document.getElementById("restartBtn").classList.add("hidden");

      updateHeartsDisplay();
      newQuestion();
    }

    // Optional: allow Enter key to login
    document.getElementById("username").addEventListener("keypress", function(e) {
      if (e.key === "Enter") {
        login();
      }
    });

    /*
      HOW TO CONNECT TO A REAL API LATER:

      Replace fakeLoginAPI(username) with something like:

      async function realLoginAPI(username) {
        const response = await fetch("https://your-api-url.com/login", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ username: username })
        });

        if (!response.ok) {
          throw new Error("Login failed.");
        }

        return await response.json();
      }

      Then in login(), replace:
      const response = await fakeLoginAPI(username);

      with:
      const response = await realLoginAPI(username);
    */
  </script>
</body>
</html>
